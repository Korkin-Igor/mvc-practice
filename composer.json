{
    "name": "korkin-igor/mvc-practice",
    "description": "Practice mvc php",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Korkin-Igor",
            "email": "korkinigor1211@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^7.4 | ^8.0",
        "illuminate/database": "13.x-dev",
        "illuminate/events": "13.x-dev",
        "nikic/fast-route": "^2.0@dev",
        "korkin-igor/collect": "dev-main",
        "phpunit/phpunit": "^13.2@dev"
    },
    "autoload": {
        "psr-4": {
            "Src\\": "core/Src/",
            "Controller\\": "app/Controller/",
            "Middlewares\\": "app/Middlewares/",
            "Model\\": "app/Model/",
            "Providers\\": "app/Providers/",
            "Service\\": "app/Service/",
            "Validators\\": "app/Validators/",
            "app\\Interfaces\\": "app/Interfaces/",
            "app\\Repositories\\": "app/Repositories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
